# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit it.

# Google OAuth 2.0 credentials (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Offline refresh token generated by scripts/get_refresh_token.py
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# LLM API key (default provider: Anthropic Claude)
# See src/meo_automation/content.py TODO to swap providers
LLM_API_KEY=your_llm_api_key_here
