# MEO Automation — environment variable template
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NEVER be committed.
#
# In production (GitHub Actions / Docker / VPS cron), set these as system or
# CI environment variables instead of using a .env file.

# --- Google OAuth 2.0 credentials ---
# Obtain from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# --- Google refresh token (one-time setup) ---
# Run: python -m meo.auth
# This opens a browser; paste the printed token here.
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# --- LLM API key ---
# Default provider: Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Optional: OpenAI (alternative provider) ---
# Only required if llm.provider is set to "openai" in config/content.yaml.
# Install the extra: pip install "meo-automation[openai]"
# OPENAI_API_KEY=your_openai_api_key_here

# --- Optional: Slack run-completion notifications ---
# Create an incoming webhook at https://api.slack.com/messaging/webhooks
# and add the URL here to receive a Slack message after each daily run.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
